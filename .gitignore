!storage/framework/sessions/.gitkeep
!storage/framework/views/.gitkeep
!storage/logs/.gitkeep

# Storage público (mantém uploads)
storage/app/public/*
!storage/app/public/.gitkeep

# Outros ficheiros temporários
/storage/*.key
/storage/pail
/public/storage

